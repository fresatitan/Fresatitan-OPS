# =============================================================================
# FRESATITAN OPS — Variables de entorno
# =============================================================================
# Copia este archivo a `.env.local` y rellena los valores de tu proyecto Supabase.
# Sin estas variables la app arranca igual pero en modo DEV (solo botones de
# selección directa de admin, sin login real con email/contraseña).

# URL del proyecto Supabase (https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Anon key del proyecto Supabase (clave pública, segura para el frontend)
VITE_SUPABASE_ANON_KEY=

# Service role key — SOLO para scripts de admin en servidor.
# NUNCA la incluyas con prefijo VITE_, nunca la expongas al frontend.
SUPABASE_SERVICE_ROLE_KEY=
